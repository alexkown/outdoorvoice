{
  "name": "outdoorvoice",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate",
    "db:migrate": "pnpm --filter @outdoorvoice/db exec prisma migrate dev",
    "db:push": "pnpm --filter @outdoorvoice/db exec prisma db push",
    "db:studio": "pnpm --filter @outdoorvoice/db exec prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
