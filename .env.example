# ============================================================
# OutdoorVoice — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ============================================================

# --- Database ---
DATABASE_URL="postgresql://outdoorvoice:outdoorvoice@localhost:5432/outdoorvoice"

# --- Redis (BullMQ) ---
REDIS_URL="redis://localhost:6379"

# --- Clerk (Auth) ---
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/overview
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/overview

# --- Twilio ---
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Anthropic (Claude) ---
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# --- ElevenLabs (TTS) ---
# Get from https://elevenlabs.io
ELEVENLABS_API_KEY=...

# --- Deepgram (STT) ---
# Get from https://console.deepgram.com
DEEPGRAM_API_KEY=...

# --- OpenAI (Embeddings — text-embedding-3-small) ---
# Get from https://platform.openai.com
OPENAI_API_KEY=sk-...

# --- Resend (Email notifications) ---
# Get from https://resend.com
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=notifications@yourdomain.com

# --- FareHarbor ---
# Platform-level app API key (issued by FareHarbor to OutdoorVoice as a platform)
# Each business supplies their own user API key during onboarding (stored in IntegrationConfig)
FAREHARBOR_APP_API_KEY=...

# --- Stripe (Billing) ---
# Get from https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Voice Agent ---
# Public hostname of the voice-agent service (used to build wss:// URLs for Twilio)
VOICE_AGENT_PUBLIC_HOST=your-voice-agent.railway.app

# --- Misc ---
NODE_ENV=development
LOG_LEVEL=info
